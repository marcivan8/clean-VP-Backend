# Environment variables — copy to .env and fill in real values
# NEVER commit .env to version control
# Set all of these in Railway's "Variables" dashboard

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here    # ⚠️ NEVER expose to client
SUPABASE_ANON_KEY=your-anon-key-here

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
# PORT is injected automatically by Railway — do not set this manually on Railway
# PORT=3000

# ─── CORS ────────────────────────────────────────────────────────────────────
# ⚠️ REQUIRED in production — a wrong value will silently break your frontend
# Set to the URL Railway assigns to YOUR frontend/backend service
# Example: https://vibed-backend-production.up.railway.app
FRONTEND_URL=https://your-railway-app.up.railway.app
PUBLIC_URL=https://your-custom-domain.com

# ─── spaCy NLP microservice ───────────────────────────────────────────────────
# Deploy spacy-service/ as a SEPARATE Railway service, then paste its URL here.
# The service is optional — if not set, AI editing degrades gracefully.
SPACY_SERVICE_URL=https://your-spacy-service.up.railway.app
SPACY_TIMEOUT=5000

# ─── WhisperX diarization microservice ───────────────────────────────────────
# Deploy diarize-service/ as a SEPARATE Railway service (or add to docker-compose),
# then paste its internal URL here. Leave blank to disable speaker diarization.
# POST /diarize returns { words: [{word, start, end, speaker}], speakers[], language }
DIARIZE_SERVICE_URL=https://your-diarize-service.up.railway.app
# Max wait time for a diarization job (ms). Default 600000 = 10 min.
DIARIZE_TIMEOUT_MS=600000
# HuggingFace token for pyannote speaker-diarization-3.1 (gated model).
# Accept the model license at https://huggingface.co/pyannote/speaker-diarization-3.1
# then create a token at https://huggingface.co/settings/tokens
HF_TOKEN=hf_...

# ─── Google Cloud Storage (required for persistent uploads on Railway) ────────
# Railway's filesystem is ephemeral — uploads WILL be lost on redeploy without GCS
# GCS_BUCKET_NAME=vibed-uploads
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccount.json

# ─── Polar.sh (billing) ──────────────────────────────────────────────────────
# Server-side API token from Polar dashboard → Settings → API Keys
# Leave blank to keep everyone on the explorer (free) tier
POLAR_ACCESS_TOKEN=
# Product IDs from Polar dashboard → Products (one per plan you sell)
POLAR_PRODUCT_PRO=
POLAR_PRODUCT_CREATOR=
# Webhook secret from Polar dashboard → Webhooks → your endpoint → Secret
POLAR_WEBHOOK_SECRET=
# Redirect URL after successful checkout — Polar replaces {CHECKOUT_ID}
POLAR_SUCCESS_URL=https://your-app.up.railway.app/upgrade/success?checkout_id={CHECKOUT_ID}

# ─── Sentry (error monitoring) ───────────────────────────────────────────────
# DSN from Sentry dashboard → Project Settings → Client Keys
# Leave blank to disable Sentry (no errors, no cost)
SENTRY_DSN=

# ─── Iubenda (cookie consent) ────────────────────────────────────────────────
# Values injected into index.html via __IUBENDA_SITE_ID__ and
# __IUBENDA_COOKIE_POLICY__ window globals (or set directly in index.html)
# IUBENDA_SITE_ID=
# IUBENDA_COOKIE_POLICY_ID=

# ─── Dev only (never set in production) ──────────────────────────────────────
# DEV_USER_ID=df851dac-...
# DEV_USER_EMAIL=dev@example.com
# Skip AI ops quota checks entirely — useful when testing locally.
# NEVER set to true in production; any paying user would bypass limits.
# BYPASS_USAGE_GATE=true
