# Environment variables — copy to .env and fill in real values
# NEVER commit .env to version control
# Set all of these in Railway's "Variables" dashboard

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here    # ⚠️ NEVER expose to client
SUPABASE_ANON_KEY=your-anon-key-here

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
# PORT is injected automatically by Railway — do not set this manually on Railway
# PORT=3000

# ─── CORS ────────────────────────────────────────────────────────────────────
# ⚠️ REQUIRED in production — a wrong value will silently break your frontend
# Set to the URL Railway assigns to YOUR frontend/backend service
# Example: https://vibed-backend-production.up.railway.app
FRONTEND_URL=https://your-railway-app.up.railway.app
PUBLIC_URL=https://your-custom-domain.com

# ─── spaCy NLP microservice ───────────────────────────────────────────────────
# Deploy spacy-service/ as a SEPARATE Railway service, then paste its URL here.
# The service is optional — if not set, AI editing degrades gracefully.
SPACY_SERVICE_URL=https://your-spacy-service.up.railway.app
SPACY_TIMEOUT=5000

# ─── Google Cloud Storage (required for persistent uploads on Railway) ────────
# Railway's filesystem is ephemeral — uploads WILL be lost on redeploy without GCS
# GCS_BUCKET_NAME=vibed-uploads
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccount.json

# ─── Dev only (never set in production) ──────────────────────────────────────
# DEV_USER_ID=df851dac-...
# DEV_USER_EMAIL=dev@example.com
