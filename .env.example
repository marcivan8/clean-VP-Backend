# Environment variables — copy to .env and fill in real values
# NEVER commit .env to version control

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
# Example: https://app.viralpilot.io,https://www.viralpilot.io
ALLOWED_ORIGINS=https://your-frontend-domain.com

# ─── Dev only (never set in production) ──────────────────────────────────────
# DEV_USER_ID=df851dac-...
# DEV_USER_EMAIL=dev@example.com
